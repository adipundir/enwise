# ───── Base Sepolia (testnet) ────────────────────────────────────────────────
#
# Single chain for now. Drop in your funded private key + an RPC URL.
# The default RPC (public base.org) is fine for occasional deploys; switch to
# Alchemy / QuickNode if you start hitting rate limits.

PRIVATE_KEY_BASE_SEPOLIA=
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# ───── Basescan verification (optional) ──────────────────────────────────────
#
# Free key from https://basescan.org/myapikey. Without it, `make verify` won't
# work but the contract still deploys + functions normally.

BASESCAN_API_KEY=
