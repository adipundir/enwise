# enwise interface env. Copy this to .env and fill in. Real .env is gitignored.

# --- Required for Phase 0 (auth + DB) ----------------------------------------

# Neon Postgres (pooled). https://console.neon.tech
DATABASE_URL=

# Auth.js. Generate: openssl rand -base64 32
AUTH_SECRET=

# At least one OAuth provider:
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Auth.js canonical URL.
AUTH_URL=http://localhost:3000

# --- Phase 1+ ----------------------------------------------------------------

# Vercel Blob (logo uploads).
BLOB_READ_WRITE_TOKEN=

# Resend (transactional email).
RESEND_API_KEY=
RESEND_FROM_ADDRESS=invoices@example.com

# Vercel Cron protection. Generate: openssl rand -hex 32
CRON_SECRET=

# Public base URL for invoice share links.
PUBLIC_BASE_URL=http://localhost:3000

# AES-256-GCM at-rest key for api_tokens. Generate: openssl rand -base64 32
TOKEN_ENC_KEY=

# --- Wallet payments ---------------------------------------------------------

# Platform fallback chain. Used only when a business has set neither
# `accepted_chain_ids` nor `payment_chain_id`. Merchants pick per business via
# MCP; the payer then chooses among the accepted chains on the share page.
#   8453   = Base mainnet (default)
#   42161  = Arbitrum One mainnet
#   84532  = Base Sepolia (testnet)
NEXT_PUBLIC_DEFAULT_CHAIN_ID=8453

# Reown / WalletConnect projectId. https://cloud.reown.com — free tier is fine.
NEXT_PUBLIC_REOWN_PROJECT_ID=

# Per-chain server-side RPC override. Each chain has its OWN var — the
# on-chain payment verifier uses the one matching the chain the payer paid on,
# so a Base URL is never used to read an Arbitrum receipt. Falls back to
# viem's public RPC if unset. Set both in production for paid Alchemy access.
# Get keys at https://dashboard.alchemy.com — create one app per chain.
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/<your-alchemy-key>
ARBITRUM_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/<your-alchemy-key>
# Ethereum mainnet (USDT payments). Set this if you accept on chain 1.
ETH_MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/<your-alchemy-key>
# BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/<your-alchemy-key>
