# ───── Dependencies + build output (any depth) ──────────────────────────────
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

.next/
out/
dist/
build/
coverage/

# ───── Env files (any depth) ────────────────────────────────────────────────
# Real secrets live here. .env.example / .env.sample are committed (kept by
# !-rules below).
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test
!.env.example
!.env.sample

# ───── OS / editor ──────────────────────────────────────────────────────────
.DS_Store
*.pem
.vscode/
.idea/

# ───── TypeScript ───────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ───── Vercel ───────────────────────────────────────────────────────────────
.vercel

# ───── Logs ─────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ───── Hardhat / contracts ──────────────────────────────────────────────────
artifacts/
cache/
typechain-types/
contract/ignition/deployments/

# ───── Test / scratch payloads ──────────────────────────────────────────────
scripts/.test-payer.json

# ───── Local Claude / memory ────────────────────────────────────────────────
.claude/
memory/

# ───── Large binary research / one-off files ────────────────────────────────
# These live at repo root but aren't code — keep them off origin.
*.docx
*.pptx
*.tex
*.skill
image.png
INSTRUCTIONS.md
# Ethereum reference docs (downloaded from ethskills.com — reference, not source)
eth-skills/
